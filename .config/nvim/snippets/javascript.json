{
    "strudel_instrument": {
        "prefix": "strudel_instrument",
        "body": [
            "// --- Core Source ---",
            "let ${1:inst}_sample = \"<PLACEHOLDER>\"",
            "let ${1:inst}_rhythm = \"<PLACEHOLDER>\"",
            "let ${1:inst}_speed = 1",
            "let ${1:inst}_transpose = 0",
            "let key = \"major\"",
            "let ${1:inst}_velocity = 1",
            "let ${1:inst}_cut = 1",
            "// --- Timing, Granular & Micro-shifts ---",
            "let ${1:inst}_chop = 0",
            "let ${1:inst}_striate = 0",
            "let ${1:inst}_loop = 1",
            "let ${1:inst}_gap = 0",
            "let ${1:inst}_nudge = 0",
            "// --- Sample Windowing ---",
            "let ${1:inst}_begin = 0",
            "let ${1:inst}_end = 1",
            "// --- ADSR ---",
            "let guitar_pick_a = 0.01",
            "let guitar_pick_d = 0.2",
            "let guitar_pick_s = 1",
            "let guitar_pick_r = 0.5",
            "",
            "// --- Pitch, Harmonics & Spectral ---",
            "let ${1:inst}_lp = 20000",
            "let ${1:inst}_lp_q = 0",
            "let ${1:inst}_hp = 0",
            "let ${1:inst}_hp_q = 0",
            "let ${1:inst}_bpf = 1000",
            "let ${1:inst}_bpq = 0",
            "let ${1:inst}_djf = 0.5",
            "let ${1:inst}_detune = 0",
            "let ${1:inst}_fshift = 0",
            "let ${1:inst}_octer = 0",
            "let ${1:inst}_octersub = 0",
            "// --- Modulation (LFOs & Audio Rate) ---",
            "let ${1:inst}_tremolo = 0",
            "let ${1:inst}_tremolorate = 1",
            "let ${1:inst}_vib = 0",
            "let ${1:inst}_vibrate = 1",
            "let ${1:inst}_ring = 0",
            "let ${1:inst}_ringf = 440",
            "let ${1:inst}_leslie = 0",
            "let ${1:inst}_lrate = 1",
            "",
            "// --- Texture & Tone ---",
            "let ${1:inst}_crush = 0",
            "let ${1:inst}_coarse = 0",
            "let ${1:inst}_squiz = 0",
            "let ${1:inst}_shape = 0",
            "let ${1:inst}_vowel = \"\"",
            "let ${1:inst}_gain_pattern = 0.5",
            "let ${1:inst}_distort = 0",
            "let ${1:inst}_phaser = 0",
            "// --- Space & Movement ---",
            "let ${1:inst}_pan = 0.5",
            "let ${1:inst}_delay = 0",
            "let ${1:inst}_delay_t = 0.25",
            "let ${1:inst}_delay_fb = 0.5",
            "let ${1:inst}_room = 0",
            "let ${1:inst}_room_size = 0.8",
            "let ${1:inst}_dry = 1",
            "let ${1:inst}_damp = 0",
            "// --- Playback & Routing Logic ---",
            "let ${1:inst}_legato = 1",
            "let ${1:inst}_unit = \"c\"",
            "let ${1:inst}_orbit = 0",
            "// --- EXECUTION CHAIN ---",
            "$: s(${1:inst}_sample).n(${1:inst}_rhythm).speed(${1:inst}_speed || 1).transpose(${1:inst}_transpose || 0).scale(key || \"major\").velocity(${1:inst}_velocity || 1).cut(${1:inst}_cut || 1).chop(${1:inst}_chop || 0).striate(${1:inst}_striate || 0).loop(${1:inst}_loop || 1).gap(${1:inst}_gap || 0).nudge(${1:inst}_nudge || 0).begin(${1:inst}_begin || 0).end(${1:inst}_end || 1).attack(guitar_pick_a || 0.01).decay(guitar_pick_d || 0.2).sustain(guitar_pick_s || 1).release(guitar_pick_r || 0.5).lpf(${1:inst}_lp || 20000).lpq(${1:inst}_lp_q || 0).hpf(${1:inst}_hp || 0).hpq(${1:inst}_hp_q || 0).bpf(${1:inst}_bpf || 1000).bpq(${1:inst}_bpq || 0).djf(${1:inst}_djf || 0.5).detune(${1:inst}_detune || 0).fshift(${1:inst}_fshift || 0).octer(${1:inst}_octer || 0).octersub(${1:inst}_octersub || 0).tremolo(${1:inst}_tremolo || 0).tremolorate(${1:inst}_tremolorate || 1).vib(${1:inst}_vib || 0).vibrate(${1:inst}_vibrate || 1).ring(${1:inst}_ring || 0).ringf(${1:inst}_ringf || 440).leslie(${1:inst}_leslie || 0).lrate(${1:inst}_lrate || 1).crush(${1:inst}_crush || 0).coarse(${1:inst}_coarse || 0).squiz(${1:inst}_squiz || 0).shape(${1:inst}_shape || 0).vowel(${1:inst}_vowel || \"\").gain(${1:inst}_gain_pattern || 0.5).distort(${1:inst}_distort || 0).phaser(${1:inst}_phaser || 0).pan(${1:inst}_pan || 0.5).delay(${1:inst}_delay || 0).delayt(${1:inst}_delay_t || 0.25).delayfb(${1:inst}_delay_fb || 0.5).room(${1:inst}_room || 0).sz(${1:inst}_room_size || 0.8).dry(${1:inst}_dry || 1).damp(${1:inst}_damp || 0).legato(${1:inst}_legato || 1).unit(${1:inst}_unit || \"c\").orbit(${1:inst}_orbit || 0)"
        ],
        "description": "A new strudel instrument"
    }
}
